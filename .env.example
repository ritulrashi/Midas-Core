# Copy to .env and fill in real values — never commit .env

# PostgreSQL
POSTGRES_USER=midas
POSTGRES_PASSWORD=midas_secret

# JWT — must be at least 32 characters (256-bit for HS256)
JWT_SECRET=replace-this-with-a-real-256-bit-secret-key-in-prod
JWT_EXPIRATION_MS=86400000

# Kafka
KAFKA_BOOTSTRAP_SERVERS=localhost:9092

# Service ports
API_GATEWAY_PORT=8080
AUTH_SERVICE_PORT=8081
TRANSACTION_SERVICE_PORT=8082
RECONCILIATION_SERVICE_PORT=8083
NOTIFICATION_WORKER_PORT=8084
LEDGER_WORKER_PORT=8085
